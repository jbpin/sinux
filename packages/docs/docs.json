{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Sinux",
  "theme": "maple",
  "colors": {
    "primary": "#6C5CE7",
    "light": "#8A7EF3",
    "dark": "#5B4AD6"
  },
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg",
    "href": "https://github.com/jbpin/sinux"
  },
  "favicon": "/images/favicon.svg",
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "heading": {
      "family": "Inter",
      "weight": 700
    }
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/jbpin/sinux"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/getting-started"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/jbpin/sinux"
    },
    "links": [
      {
        "header": "Docs",
        "items": [
          { "label": "Introduction", "href": "/introduction" },
          { "label": "Getting Started", "href": "/getting-started" }
        ]
      },
      {
        "header": "Community",
        "items": [
          { "label": "GitHub Issues", "href": "https://github.com/jbpin/sinux/issues" }
        ]
      }
    ]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "getting-started"]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/store",
              "concepts/signals",
              "concepts/middleware",
              "concepts/computed"
            ]
          },
          {
            "group": "React",
            "pages": [
              "react/use-store",
              "react/use-computed",
              "react/combine"
            ]
          },
          {
            "group": "Middlewares",
            "pages": [
              "middlewares/persist",
              "middlewares/devtools",
              "middlewares/immer"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/tanstack-query",
              "integrations/apollo"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/todo-app",
              "examples/contact-store",
              "examples/multi-store"
            ]
          },
          {
            "group": "Ecosystem",
            "pages": ["plugins"]
          }
        ]
      }
    ]
  }
}
